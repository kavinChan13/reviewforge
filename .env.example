# ReviewForge configuration — copy to .env and fill in.
# Provider layer is OpenAI-compatible: point it at OpenAI, an internal gateway,
# Ollama (http://localhost:11434/v1), DashScope, etc. Only base_url + model change.

# --- Chat LLM (used by review agents) ---
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=PLACEHOLDER_fill_me_in
LLM_MODEL=gpt-4o-mini
# Sampling temperature for review reasoning (lower = more deterministic)
LLM_TEMPERATURE=0.1

# --- Embeddings (used by codebase index / semantic_search) ---
# Defaults to the chat endpoint/key if left unset.
EMBED_BASE_URL=
EMBED_API_KEY=
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536

# --- Static analysis (optional; auto-detected if on PATH) ---
CLANG_TIDY_PATH=clang-tidy

# --- Runtime ---
RF_DATA_DIR=./.reviewforge
RF_MIN_CONFIDENCE=0.6
RF_CONCURRENCY=3
# Disk response cache for LLM calls (1=on, 0=off).
RF_CACHE=1
# Max diff characters sent to a reviewer before truncation.
RF_MAX_DIFF_CHARS=12000
# Optional cheap model to triage which dimensions to run (empty = run all).
LLM_TRIAGE_MODEL=
# Optional stronger/different model for `rf eval --judge` (LLM-as-Judge).
JUDGE_MODEL=

# --- Review sinks (optional; required only when using --post) ---
# GitHub PR (works in GitHub Actions automatically; just provide a token).
GITHUB_REPOSITORY=
GITHUB_PR_NUMBER=
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com

# Gerrit (HTTP API; needs an HTTP password from your Gerrit user settings).
GERRIT_URL=
GERRIT_CHANGE_ID=
GERRIT_REVISION=current
GERRIT_USER=
GERRIT_HTTP_PASSWORD=
